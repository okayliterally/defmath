<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Student Dashboard - Assignments, Resources & Study Tools">
  <meta name="theme-color" content="#0a0a0f">
  <title>Student Dashboard</title>
  <link rel="icon" type="image/png" href="https://image2url.com/r2/default/images/1772114193046-733bfa71-77a7-4fdc-bce4-d3e8ebe17a29.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="styles.css">
</head>
<body data-theme="dark">
  <div class="loading-screen" id="loadingScreen">
    <img class="loading-logo" src="https://image2url.com/r2/default/images/1772114193046-733bfa71-77a7-4fdc-bce4-d3e8ebe17a29.png" alt="Logo">
    <h1 class="loading-title">Student Dashboard</h1>
    <div class="loading-bar-container">
      <div class="loading-bar"></div>
    </div>
    <p class="loading-text">loading resources...</p>
  </div>

  <div class="exit-overlay" id="exitOverlay">
    <i class="fas fa-graduation-cap"></i>
    <span>Redirecting to Google Classroom...</span>
  </div>

  <div class="app">
    <button class="sidebar-open-btn" id="sidebarOpenBtn"><i class="fas fa-chevron-left"></i></button>
    
    <aside class="sidebar" id="sidebar">
      <button class="sidebar-close-btn" id="sidebarCloseBtn"><i class="fas fa-chevron-right"></i></button>
      
      <div class="logo">
        <img src="https://image2url.com/r2/default/images/1772114193046-733bfa71-77a7-4fdc-bce4-d3e8ebe17a29.png" alt="Logo">
        <span class="logo-text">sight.math</span>
      </div>

      <div class="time-card">
        <div class="time" id="time">00:00</div>
        <div class="date" id="date">Monday, Jan 1</div>
      </div>

      <ul class="nav-list">
        <li class="nav-item"><a class="nav-link active" id="homeLink"><i class="fas fa-house"></i> Home</a></li>
        <li class="nav-item"><a class="nav-link" id="toolsLink"><i class="fas fa-shapes"></i> Practice</a></li>
        <li class="nav-item"><a class="nav-link" id="mediaLink"><i class="fas fa-photo-film"></i> Media</a></li>
        <li class="nav-item"><a class="nav-link" id="chatLink"><i class="fas fa-comments"></i> Discussion</a></li>
        <li class="nav-item"><a class="nav-link" id="partnersLink"><i class="fas fa-handshake"></i> Partners</a></li>
      </ul>

      <div class="sidebar-footer">
        <div class="footer-link" id="settingsLink"><i class="fas fa-gear"></i> Settings</div>
        <div class="footer-link" id="creditsLink"><i class="fas fa-heart"></i> Credits</div>
        <div class="footer-link" id="legalLink"><i class="fas fa-scale-balanced"></i> Legal</div>
      </div>
    </aside>

    <div class="main-wrapper" id="mainWrapper">
      <main class="main" id="homePage">
        <header class="main-header">
          <h1 class="main-title">sight.math</h1>
          <p class="main-subtitle">study resources & tools for students</p>
        </header>

        <div class="info-box">
          <div class="info-box-header">
            <i class="fas fa-lightbulb"></i>
            <h3 class="info-box-title">resources</h3>
          </div>
          <div class="info-box-content">
            <ul>
              <li>Tab title customization</li>
              <li>Quick exit button (P key)</li>
              <li>Fullscreen focus mode</li>
            </ul>
            <a href="https://github.com/NITRObrah" target="_blank" class="info-box-link">
              <i class="fab fa-github"></i> source
            </a>
          </div>
        </div>

        <div class="info-box">
          <div class="info-box-header">
            <i class="fas fa-circle-info"></i>
            <h3 class="info-box-title">status</h3>
          </div>
          <div class="info-box-content">
            <p>updating study materials...</p>
          </div>
        </div>
      </main>

      <div class="fullpage-view" id="toolsPage">
        <div class="tools-menu" id="toolsMenu">
          <div class="games-option" id="firstToolsBtn">
            <i class="fas fa-book-open"></i>
            <h3 class="games-option-title">Study Set A</h3>
            <p class="games-option-desc">500+ exercises</p>
          </div>
          <div class="games-option" id="secondToolsBtn">
            <i class="fas fa-flask"></i>
            <h3 class="games-option-title">Study Set B</h3>
            <p class="games-option-desc">extended collection</p>
            <span class="badge-rec">RECOMMENDED</span>
          </div>
        </div>

        <header class="fullpage-header" id="toolsHeader" style="display: none;">
          <h2 class="fullpage-title"><i class="fas fa-shapes"></i> Practice</h2>
          <div class="fullpage-btns">
            <button class="fullpage-btn" id="toolsBack" style="display: none;"><i class="fas fa-arrow-left"></i> Back</button>
            <button class="fullpage-btn" id="toolsReload" style="display: none;"><i class="fas fa-rotate-right"></i> Reload</button>
            <button class="fullpage-btn home-btn" id="toolsHome"><i class="fas fa-house"></i> Home</button>
          </div>
        </header>

        <div class="fullpage-body" id="toolsIframeContainer" style="display: none;">
          <iframe class="fullpage-iframe" id="toolsIframe" title="Practice" allow="fullscreen *; gamepad *;" allowfullscreen sandbox="allow-scripts allow-same-origin allow-forms allow-pointer-lock"></iframe>
        </div>

        <div class="second-games" id="secondToolsContainer" style="display: none;">
          <div class="second-games-header">
            <input type="text" class="second-games-search" id="toolsSearchInput" placeholder="Search exercises...">
          </div>
          <div class="second-games-grid" id="toolsGrid"></div>
        </div>

        <div class="game-player-view" id="toolPlayerView">
          <header class="game-player-header">
            <h2 class="game-player-title"><i class="fas fa-shapes"></i> <span id="toolPlayerTitle">Exercise</span></h2>
            <div class="game-player-btns">
              <button class="fullpage-btn" id="toolPlayerReload"><i class="fas fa-rotate-right"></i> Reload</button>
              <button class="fullpage-btn accent-btn" id="toolPlayerEmbed"><i class="fas fa-code"></i> Embed</button>
              <button class="fullpage-btn" id="toolPlayerBack"><i class="fas fa-arrow-left"></i> Back</button>
            </div>
          </header>
          <div class="game-player-body">
            <div class="game-player-loading" id="toolPlayerLoading">
              <i class="fas fa-circle-notch"></i>
              <span>Loading content...</span>
            </div>
            <div class="pointer-lock-hint" id="pointerLockHint">Click to focus | Press ESC to release</div>
            <iframe class="game-player-iframe" id="toolPlayerIframe" title="Practice" allow="fullscreen *; gamepad *; clipboard-write *; pointer-lock *;" allowfullscreen></iframe>
          </div>
        </div>
      </div>

      <div class="fullpage-view" id="mediaPage">
        <header class="fullpage-header">
          <h2 class="fullpage-title"><i class="fas fa-photo-film"></i> Media</h2>
          <div class="fullpage-btns">
            <button class="fullpage-btn" id="mediaReload"><i class="fas fa-rotate-right"></i> Reload</button>
            <button class="fullpage-btn home-btn" id="mediaHome"><i class="fas fa-house"></i> Home</button>
          </div>
        </header>
        <div class="fullpage-body">
          <iframe class="fullpage-iframe" id="mediaIframe" title="Media" allow="fullscreen *;" allowfullscreen sandbox="allow-scripts allow-same-origin allow-forms allow-pointer-lock"></iframe>
        </div>
      </div>

      <div class="chat-page" id="chatPage">
        <header class="fullpage-header">
          <h2 class="fullpage-title"><i class="fas fa-comments"></i> Discussion</h2>
          <div class="fullpage-btns">
            <button class="fullpage-btn home-btn" id="chatHome"><i class="fas fa-house"></i> Home</button>
          </div>
        </header>
        <div class="chat-body" id="chatBody"></div>
      </div>

      <div class="partners-page" id="partnersPage">
        <div class="partners-content">
          <button class="partners-back" id="partnersBack"><i class="fas fa-arrow-left"></i> Back</button>
          <div class="partners-header">
            <h2 class="partners-title">Partners</h2>
          </div>
          <div class="partners-grid">
            <article class="partner-card" id="partnerFormCard">
              <div class="partner-logo-wrap"><i class="fas fa-handshake"></i></div>
              <h3 class="partner-name">Partner Form</h3>
              <p class="partner-desc">want to partner? fill this out</p>
            </article>
            <article class="partner-card">
              <div class="partner-logo-wrap"><i class="fas fa-question"></i></div>
              <h3 class="partner-name">Your site?</h3>
              <p class="partner-desc">use the form</p>
            </article>
          </div>
        </div>
      </div>

      <div class="settings-page" id="settingsPage">
        <div class="settings-content">
          <button class="settings-back" id="settingsBack"><i class="fas fa-arrow-left"></i> Back</button>
          <div class="settings-header">
            <h2 class="settings-title">Settings</h2>
          </div>

          <div class="settings-section">
            <h3 class="settings-section-title"><i class="fas fa-palette"></i> Theme</h3>
            <div class="theme-grid">
              <button class="theme-btn theme-dark" data-theme="dark">Dark</button>
              <button class="theme-btn theme-light" data-theme="light">Light</button>
              <button class="theme-btn theme-ocean" data-theme="ocean">Ocean</button>
              <button class="theme-btn theme-forest" data-theme="forest">Forest</button>
              <button class="theme-btn theme-earthy" data-theme="earthy">Earthy</button>
              <button class="theme-btn theme-neon" data-theme="neon">Neon</button>
              <button class="theme-btn theme-sunset" data-theme="sunset">Sunset</button>
            </div>
          </div>

          <div class="settings-section">
            <h3 class="settings-section-title"><i class="fas fa-gauge-high"></i> Performance</h3>
            <div class="toggle-row">
              <span class="toggle-text">FPS Booster <small>Disable animations</small></span>
              <button class="toggle-switch on" id="toggleFpsBooster"></button>
            </div>
            <div class="toggle-row">
              <span class="toggle-text">Show Stats</span>
              <button class="toggle-switch" id="toggleStats"></button>
            </div>
            <div class="toggle-row">
              <span class="toggle-text">Blur Effects</span>
              <button class="toggle-switch on" id="toggleBlur"></button>
            </div>
          </div>

          <div class="settings-section">
            <h3 class="settings-section-title"><i class="fas fa-wand-magic-sparkles"></i> Tools</h3>
            <div class="bypass-grid">
              <button class="bypass-btn" id="focusModeBtn">
                <i class="fas fa-expand"></i>
                Focus Mode
              </button>
              <button class="bypass-btn exit-btn" id="exitBtn">
                <i class="fas fa-right-from-bracket"></i>
                Quick Exit (P)
              </button>
            </div>
          </div>

          <div class="settings-section">
            <h3 class="settings-section-title"><i class="fas fa-tag"></i> Display Name</h3>
            <div class="cloak-grid">
              <button class="cloak-btn active" data-cloak="default"><i class="fas fa-eye"></i>sight.w</button>
              <button class="cloak-btn" data-cloak="canvas"><img src="https://canvas.instructure.com/favicon.ico" alt="">Canvas</button>
              <button class="cloak-btn" data-cloak="google"><img src="https://www.google.com/favicon.ico" alt="">Google</button>
              <button class="cloak-btn" data-cloak="drive"><img src="https://drive.google.com/favicon.ico" alt="">Drive</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="kbd-hint">
    <span><kbd>A</kbd> Practice</span>
    <span><kbd>M</kbd> Media</span>
    <span><kbd>H</kbd> Home</span>
    <span><kbd>P</kbd> Exit</span>
  </div>

  <div class="modal-overlay" id="embedModal">
    <div class="modal">
      <header class="modal-header">
        <h2 class="modal-title"><i class="fas fa-code"></i> Embed Code</h2>
        <button class="modal-close" id="embedClose"><i class="fas fa-xmark"></i></button>
      </header>
      <div class="modal-body">
        <textarea class="embed-code" id="embedCode" readonly></textarea>
        <button class="copy-btn" id="copyEmbedBtn">Copy to Clipboard</button>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="creditsModal">
    <div class="modal">
      <header class="modal-header">
        <h2 class="modal-title"><i class="fas fa-heart"></i> Credits</h2>
        <button class="modal-close" id="creditsClose"><i class="fas fa-xmark"></i></button>
      </header>
      <div class="modal-body">
        <div class="credits-block">
          <div class="credits-label">Resources</div>
          <div class="credits-item-title">NativeLite</div>
          <div class="credits-item-note">from <a href="https://github.com/parcoillegacy/nativelite" target="_blank">parcoillegacy/nativelite</a></div>
        </div>
        <div class="credits-block">
          <div class="credits-label">Thanks</div>
          <div class="credits-item-title">Infrastructure</div>
          <div class="credits-item-note">mathpunch Official</div>
        </div>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="legalModal">
    <div class="modal">
      <header class="modal-header">
        <h2 class="modal-title"><i class="fas fa-scale-balanced"></i> Legal</h2>
        <button class="modal-close" id="legalClose"><i class="fas fa-xmark"></i></button>
      </header>
      <div class="modal-body">
        <div class="legal-tabs">
          <button class="legal-tab active" data-tab="tos">Terms</button>
          <button class="legal-tab" data-tab="privacy">Privacy</button>
        </div>
        <div class="legal-content" id="tosContent">
          <h3>1. Acceptance</h3>
          <p>By using this dashboard, you accept these terms.</p>
          <h3>2. Use</h3>
          <p>For educational and personal use only.</p>
          <h3>3. Disclaimer</h3>
          <p>Provided "as is" without warranties.</p>
        </div>
        <div class="legal-content" id="privacyContent" style="display: none;">
          <h3>1. Data</h3>
          <p>We collect minimal info for operation.</p>
          <h3>2. Storage</h3>
          <p>Preferences saved locally on your device.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="stats-overlay" id="statsOverlay">
    <div class="stat-row"><span class="stat-label">FPS</span><span class="stat-value" id="fpsValue">60</span></div>
    <div class="stat-row"><span class="stat-label">Ping</span><span class="stat-value" id="pingValue">--</span></div>
    <div class="stat-row"><span class="stat-label">Battery</span><span class="stat-value" id="batteryValue">--</span></div>
  </div>

  <script src="script.js"></script>
</body>
</html>
